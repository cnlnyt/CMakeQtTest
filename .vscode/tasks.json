{
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: g++.exe 生成活动文件",
			"command": "D:\\Qt\\mingw64\\bin\\g++.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${file}",
				"-o",
				"${fileDirname}\\${fileBasenameNoExtension}.exe"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
			"detail": "调试器生成的任务。"
		},
		{
			"label": "Open Qt Designer (current file)",
			"type": "shell",
			"command": "D:\\Qt\\Qt5.14.2\\5.14.2\\mingw73_64\\bin\\designer.exe",
			"args": [
				"${file}"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "none"
		}
	],
	"version": "2.0.0"
}